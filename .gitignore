# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude any .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based. If you would like to include them then 
# you should create a .tfvars.example file
# *.tfvars
# *.tfvars.json

# Ignore override files as they are usually used for local overriding.
# Override files for Terraform should be named either override.tf or 
# override.tf.json. Alternatively, they can be named with a suffix 
# _override.tf or _override.tf.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for modules in directories
**/*_override.tf
**/*_override.tf.json

# Include terraform.rc and .terraformrc.
# These files are used for local configuration of Terraform.
terraform.rc
.terraformrc

# General
.DS_Store
*.swp
*~
.idea/
.vscode/
.history/
